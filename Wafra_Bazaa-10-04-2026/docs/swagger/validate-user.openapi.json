          "200": { "$ref": "#/components/responses/SuccessOrBusinessErrorResponse" },
          "401": { "$ref": "#/components/responses/UnauthorizedResponse" },
          "500": { "$ref": "#/components/responses/ServerErrorResponse" }
        }
      }
    },
    "/api/v1/user/address/update": {
      "put": {
        "tags": ["User"],
        "summary": "Update address",
        "security": [{ "apiKeyAuth": [] }, { "tokenAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateAddressRequest" }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/SuccessOrBusinessErrorResponse" },
          "401": { "$ref": "#/components/responses/UnauthorizedResponse" },
          "500": { "$ref": "#/components/responses/ServerErrorResponse" }
        }
      }
