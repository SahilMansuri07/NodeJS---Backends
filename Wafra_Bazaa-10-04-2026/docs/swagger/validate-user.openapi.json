  },
  "components": {
    "responses": {
      "SuccessOrBusinessErrorResponse": {
        "description": "Operation response where code can indicate success or business validation error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ApiResponse" },
            "examples": {
              "success": {
                "value": { "code": 1, "message": "Success!", "data": null }
              },
              "businessError": {
                "value": { "code": 0, "message": "Required fields are missing", "data": null }
              }
            }
          }
        }
      },
      "UnauthorizedResponse": {
        "description": "Missing or invalid API key/token",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ApiResponse" },
            "examples": {
              "missingToken": {
                "value": { "code": 0, "message": "Token missing" }
              },
              "invalidApiKey": {
                "value": { "code": -1, "message": "Unauthorized" }
              }
            }
          }
        }
      },
      "ServerErrorResponse": {
        "description": "Unexpected server error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ApiResponse" },
            "example": { "code": 0, "message": "An error occurred" }
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "api-key",
        "description": "Required by api-key middleware for protected routes."
      },
      "tokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "token",
        "description": "Bearer token used by token middleware. You can also send it in the Authorization header as 'Bearer <token>'."
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "integer", "example": 1 },
          "message": { "type": "string", "example": "Success!" },
          "data": { "nullable": true }
        },
        "required": ["code", "message"]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "country_code": { "type": "string", "example": "+91" },
          "mobile_number": { "type": "string", "example": "9510447952" },
          "password": { "type": "string", "example": "123456" },
          "social_id": { "type": "string", "example": "social_123" },
          "login_type": { "type": "string", "enum": ["G", "A", "F", "S"] }
        }
      },
      "AddAddressRequest": {
        "type": "object",
        "required": ["user_id", "name", "address_line_1", "city", "state", "country", "postal_code"],
        "properties": {
          "user_id": { "type": "integer", "example": 16 },
          "name": { "type": "string", "example": "Sahil" },
          "company_name": { "type": "string", "nullable": true },
          "address_line_1": { "type": "string", "example": "Palm Street" },
          "address_line_2": { "type": "string", "nullable": true },
          "latitude": { "type": "string", "nullable": true },
          "longitude": { "type": "string", "nullable": true },
          "city": { "type": "string", "example": "Ahmedabad" },
          "state": { "type": "string", "example": "Gujarat" },
          "country": { "type": "string", "example": "India" },
          "postal_code": { "type": "string", "example": "380001" },
          "is_default": { "type": "integer", "example": 1 }
        }
      },
      "ValidateUserRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "sahil@example.com"
          },
          "mobile_number": {
            "type": "string",
            "example": "9510447952"
          },
          "country_code": {
            "type": "string",
            "example": "+91"
          },
          "social_id": {
            "type": "string",
            "example": "social_12345"
          },
          "login_type": {
            "type": "string",
            "enum": [
              "G",
              "A",
              "F",
              "S"
            ],
            "example": "G"
          },
          "name": {
            "type": "string",
            "example": "Sahil"
          }
        },
        "additionalProperties": false,
        "description": "All fields are optional in implementation; provide one of: email OR (country_code + mobile_number) OR (social_id + login_type)."
      },
      "RequestOtpRequest": {
        "type": "object",
        "properties": {
          "country_code": { "type": "string", "example": "+91" },
          "mobile_number": { "type": "string", "example": "9510447952" },
          "email": { "type": "string", "format": "email" },
          "type": { "type": "string", "example": "s" },
          "otp_purpose": { "type": "string", "example": "signup" }
        }
      },
      "VerifyOtpRequest": {
        "type": "object",
        "required": ["otp"],
        "properties": {
          "country_code": { "type": "string", "example": "+91" },
          "mobile_number": { "type": "string", "example": "9510447952" },
          "email": { "type": "string", "format": "email" },
          "name": { "type": "string", "example": "Sahil" },
          "password": { "type": "string", "example": "123456" },
          "login_type": { "type": "string", "enum": ["G", "A", "F", "S"] },
          "language": { "type": "string", "example": "en" },
          "otp": { "type": "integer", "example": 1234 }
        }
      },
      "ForgetPasswordRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "format": "email", "example": "sahil@example.com" }
        }
      },
      "VerifyForgetPasswordOtpRequest": {
        "type": "object",
        "required": ["email", "otp"],
        "properties": {
          "email": { "type": "string", "format": "email", "example": "sahil@example.com" },
          "otp": { "type": "integer", "example": 1234 },
          "new_password": { "type": "string", "example": "NewPassword@123" }
        }
      },
      "ResetPasswordRequest": {
        "type": "object",
        "required": ["email", "new_password"],
        "properties": {
          "email": { "type": "string", "format": "email", "example": "sahil@example.com" },
          "new_password": { "type": "string", "example": "NewPassword@123" }
        }
      },
      "UpdateProfileRequest": {
        "type": "object",
        "required": ["user_id"],
        "properties": {
          "user_id": { "type": "integer", "example": 16 },
          "profile_image": { "type": "string", "example": "https://example.com/profile.jpg" },
          "is_skip": { "type": "integer", "example": 0 }
        }
      },
      "SetProfileRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "example": "Sahil" },
          "email": { "type": "string", "format": "email", "example": "sahil@example.com" },
          "country_code": { "type": "string", "example": "+91" },
          "phone": { "type": "string", "example": "9510447952" },
          "profile_image": { "type": "string", "example": "https://example.com/profile.jpg" }
        }
      },
      "SetLanguageRequest": {
        "type": "object",
        "required": ["language"],
        "properties": {
          "language": { "type": "string", "enum": ["en", "ar"], "example": "en" }
        }
      },
      "ChangePasswordRequest": {
        "type": "object",
        "required": ["old_password", "new_password"],
        "properties": {
          "old_password": { "type": "string", "example": "OldPassword@123" },
          "new_password": { "type": "string", "example": "NewPassword@123" }
        }
      },
      "CartManageRequest": {
        "type": "object",
        "required": ["product_id", "quantity"],
        "properties": {
          "product_id": { "type": "integer", "example": 1 },
          "size_id": { "type": "integer", "nullable": true },
          "color_id": { "type": "integer", "nullable": true },
          "type_id": { "type": "integer", "nullable": true },
          "quantity": { "type": "integer", "example": 1 }
        }
      },
      "CartRemoveRequest": {
        "type": "object",
        "properties": {
          "product_id": { "type": "integer", "example": 1 },
          "variant_id": { "type": "integer", "example": 10 },
          "quantity": { "type": "integer", "example": 0 }
        }
      },
      "AddPaymentMethodRequest": {
        "type": "object",
        "required": ["card_number", "payment_mode"],
        "properties": {
          "holder_name": { "type": "string", "example": "Sahil" },
          "card_number": { "type": "string", "example": "4111111111111111" },
          "expiry_date": { "type": "string", "example": "12/29" },
          "payment_mode": { "type": "string", "example": "card" },
          "upi_id": { "type": "string", "nullable": true },
          "cvv": { "type": "string", "nullable": true }
        }
      },
      "PlaceOrderRequest": {
        "type": "object",
        "properties": {
          "user_latitude": { "type": "string", "nullable": true },
          "user_longitude": { "type": "string", "nullable": true },
          "user_location": { "type": "string", "nullable": true },
          "subtotal": { "type": "number", "example": 120.5 },
          "tax": { "type": "number", "example": 5 },
          "discount": { "type": "number", "example": 2 },
          "total": { "type": "number", "example": 123.5 },
          "payment_mode": { "type": "string", "example": "card" },
          "payment_card_number": { "type": "string", "nullable": true },
          "payment_id": { "type": "integer", "nullable": true }
        }
      },
      "FavouriteRequest": {
        "type": "object",
        "required": ["product_id"],
        "properties": {
          "product_id": { "type": "integer", "example": 1 }
        }
      },
      "AddRatingRequest": {
        "type": "object",
        "required": ["product_id", "rating"],
        "properties": {
          "product_id": { "type": "integer", "example": 1 },
          "rating": { "type": "integer", "minimum": 1, "maximum": 5, "example": 5 },
          "review": { "type": "string", "nullable": true }
        }
      },
      "CancelOrderRequest": {
        "type": "object",
        "properties": {
          "order_id": { "type": "integer", "example": 101 },
          "order_code": { "type": "string", "example": "ORD-1713091200000-123" }
        }
      },
      "SetAddressRequest": {
        "type": "object",
        "required": ["address_id"],
        "properties": {
          "address_id": { "type": "integer", "example": 3 }
        }
      },
      "UpdateAddressRequest": {
        "type": "object",
        "required": ["address_id"],
        "properties": {
          "address_id": { "type": "integer", "example": 3 },
          "name": { "type": "string", "example": "Sahil" },
          "address_line_1": { "type": "string", "example": "Flat 302" },
          "address_line_2": { "type": "string", "nullable": true },
          "city": { "type": "string", "example": "Ahmedabad" },
          "state": { "type": "string", "example": "Gujarat" },
          "country": { "type": "string", "example": "India" },
          "postal_code": { "type": "string", "example": "380015" },
          "latitude": { "type": "string", "nullable": true },
          "longitude": { "type": "string", "nullable": true }
        }
      },
      "DeleteAddressRequest": {
        "type": "object",
        "required": ["address_id"],
        "properties": {
          "address_id": { "type": "integer", "example": 3 }
        }
      },
      "DecryptedResponseExample": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 1
          },
          "message": {
            "type": "string",
            "example": "rest_keywords_success"
          },
          "data": {
            "nullable": true
          }
        }
      }
    }
  }
}