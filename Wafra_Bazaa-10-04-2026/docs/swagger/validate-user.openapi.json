    "/api/v1/auth/validate-user": {
      "post": {
        "tags": ["Auth"],
        "summary": "Validate user details",
        "description": "Validates whether email, mobile, or social account already exists. If social_id + login_type are provided and not found, it creates a verified social user.",
        "security": [{ "apiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ValidateUserRequest" },
              "examples": {
                "emailCheck": {
                  "summary": "Validate by email",
                  "value": { "email": "sahil@example.com" }
                },
                "mobileCheck": {
                  "summary": "Validate by mobile",
                  "value": { "country_code": "+91", "mobile_number": "9510447952" }
                },
                "socialCheck": {
                  "summary": "Validate social and create user",
                  "value": {
                    "name": "Sahil",
                    "email": "sahil.social@example.com",
                    "country_code": "+91",
                    "mobile_number": "9510447952",
                    "login_type": "G",
                    "social_id": "social_12345"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Encrypted API response",
            "content": {
              "application/json": {
                "schema": { "type": "string", "description": "AES-encrypted payload" },
                "examples": {
                  "success": {
                    "summary": "Success response after validation",
                    "value": { "code": 1, "message": "Success!", "data": null }
                  },
                  "emailExists": {
                    "summary": "Email already exists",
                    "value": { "code": 0, "message": "Email already exists. Please try with different email", "data": null }
                  },
                  "socialCreated": {
                    "summary": "Social user created",
                    "value": {
                      "code": 1,
                      "message": "User validated and created successfully",
                      "data": {
                        "userData": [{ "id": 16, "email": "sahil.social@example.com" }],
                        "token": "JWT_TOKEN_VALUE"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/UnauthorizedResponse" },
          "500": {
            "$ref": "#/components/responses/ServerErrorResponse"
          }
        }
      }
    },
